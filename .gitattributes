# Exclude root-level files and folders from git archive (GitHub releases, git archive zips)
/.gitattributes export-ignore
/.gitignore export-ignore
/.godot/ export-ignore
/LICENSE export-ignore
/project.godot export-ignore
/README.md export-ignore

# Exclude tests
/tests/ export-ignore
/.gutconfig.json export-ignore

# Exclude all addon folders by default, then include only the specific one
/addons/* export-ignore
/addons/nildevgames_directional_movement_2d/ -export-ignore
